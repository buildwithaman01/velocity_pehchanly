{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "pehchanly-client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/server.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "pehchanly-client/assets/$1"
    },
    {
      "source": "/favicon.png",
      "destination": "pehchanly-client/favicon.png"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "pehchanly-client/index.html"
    }
  ]
}
